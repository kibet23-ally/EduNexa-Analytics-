// src/middleware.ts
// Route protection based on school status.
// Uses public.users (real schema) not public.profiles.

import { createServerClient } from '@supabase/ssr';
import { NextResponse, type NextRequest } from 'next/server';

// Routes that never require auth
const PUBLIC_ROUTES = new Set([
  '/', '/register', '/login', '/awaiting-approval', '/account-suspended',
]);

// Routes that are always accessible once logged in (regardless of school status)
const AUTH_OPEN_ROUTES = new Set(['/awaiting-approval', '/account-suspended']);

export async function middleware(request: NextRequest) {
  let response = NextResponse.next({ request });

  const supabase = createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    {
      cookies: {
        getAll: () => request.cookies.getAll(),
        setAll: (cookiesToSet) => {
          cookiesToSet.forEach(({ name, value }) => request.cookies.set(name, value));
          response = NextResponse.next({ request });
          cookiesToSet.forEach(({ name, value, options }) =>
            response.cookies.set(name, value, options)
          );
        },
      },
    }
  );

  const { data: { user } } = await supabase.auth.getUser();
  const { pathname }       = request.nextUrl;

  // ── Skip API routes entirely ─────────────────────────────
  if (pathname.startsWith('/api/')) return response;

  // ── Public pages — always accessible ────────────────────
  if (PUBLIC_ROUTES.has(pathname)) {
    // Redirect already-logged-in users away from /login and /register
    if (user && (pathname === '/login' || pathname === '/register')) {
      return redirectByStatus(supabase, user.id, request);
    }
    return response;
  }

  // ── Not logged in — send to login ─────────────────────────
  if (!user) {
    return NextResponse.redirect(new URL('/login', request.url));
  }

  // ── Logged in — fetch role + school status ───────────────
  const { data: userRow } = await supabase
    .from('users')
    .select('role, school_id')
    .eq('auth_id', user.id)
    .single();

  // Super admin — unrestricted access
  if (userRow?.role === 'super_admin') {
    return response;
  }

  // Protect /admin/* from non-super-admins
  if (pathname.startsWith('/admin')) {
    return NextResponse.redirect(new URL('/dashboard', request.url));
  }

  // Fetch school status
  let status: string | null = null;
  if (userRow?.school_id) {
    const { data: school } = await supabase
      .from('schools')
      .select('status')
      .eq('id', userRow.school_id)
      .single();
    status = school?.status ?? null;
  }

  // ── Status-based routing ─────────────────────────────────
  if (status === 'pending' && !AUTH_OPEN_ROUTES.has(pathname)) {
    return NextResponse.redirect(new URL('/awaiting-approval', request.url));
  }

  if (status === 'suspended' && pathname !== '/account-suspended') {
    return NextResponse.redirect(new URL('/account-suspended', request.url));
  }

  // Active school trying to visit restriction pages → dashboard
  if (status === 'active' && AUTH_OPEN_ROUTES.has(pathname)) {
    return NextResponse.redirect(new URL('/dashboard', request.url));
  }

  return response;
}

// ── Helper: redirect based on user's current school status ──
async function redirectByStatus(supabase: ReturnType<typeof createServerClient>, userId: string, request: NextRequest) {
  const { data: userRow } = await supabase
    .from('users')
    .select('role, school_id')
    .eq('auth_id', userId)
    .single();

  if (userRow?.role === 'super_admin') {
    return NextResponse.redirect(new URL('/admin', request.url));
  }

  if (!userRow?.school_id) {
    return NextResponse.redirect(new URL('/awaiting-approval', request.url));
  }

  const { data: school } = await supabase
    .from('schools')
    .select('status')
    .eq('id', userRow.school_id)
    .single();

  if (school?.status === 'pending')   return NextResponse.redirect(new URL('/awaiting-approval', request.url));
  if (school?.status === 'suspended') return NextResponse.redirect(new URL('/account-suspended', request.url));
  return NextResponse.redirect(new URL('/dashboard', request.url));
}

export const config = {
  matcher: [
    '/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
  ],
};
