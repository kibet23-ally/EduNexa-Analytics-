# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: A random secure string for signing session tokens.
JWT_SECRET="your-jwt-secret-here"

# Supabase Configuration (Backend-only / Private)
# IMPORTANT: Put these in your AI Studio "Secrets" or local .env file.
# The backend uses these to communicate with Supabase.
SUPABASE_URL="https://zclwokyzsqzitqwmugtt.supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Supabase Configuration (Frontend / Public)
# Only variables prefixed with VITE_ are exposed to the browser.
VITE_SUPABASE_URL="https://zclwokyzsqzitqwmugtt.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# API Configuration (Frontend points to Backend)
VITE_API_BASE_URL=""

# Optional: Initial SuperAdmin Credentials (bootstrapped on first run)
# After setting these, log in once at /login to create the account.
ADMIN_EMAIL="support@edunexa.com"
ADMIN_PASSWORD="EduNexa2024!"
